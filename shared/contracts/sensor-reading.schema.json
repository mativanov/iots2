{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.edu/iot-event-brokers/sensor-reading.schema.json",
  "title": "SensorReading",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "messageId",
    "deviceId",
    "temperature",
    "humidity",
    "createdAt"
  ],
  "properties": {
    "messageId": {
      "type": "string"
    },
    "deviceId": {
      "type": "string"
    },
    "temperature": {
      "type": "number"
    },
    "humidity": {
      "type": "number"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp"
    }
  }
}
